{
  "_comment": "Documented scoped permissions for the resolver. Not loaded at runtime when cc-crew dispatches this persona with --dangerously-skip-permissions.",
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(gh pr view:*)",
      "Bash(gh auth setup-git)",
      "Bash(make:*)",
      "Bash(go:*)",
      "Bash(npm:*)",
      "Bash(pnpm:*)",
      "Bash(yarn:*)",
      "Bash(pytest:*)",
      "Bash(cargo:*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(rm -rf:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh pr create:*)"
    ]
  }
}
